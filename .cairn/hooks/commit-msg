#!/bin/sh
# Generated by Cairn from cairn.yaml (hooks.commit_msg). Re-run `cairn init` to update.
set -e

# GUI git clients often run hooks with a minimal PATH; append the usual per-OS tool
# dirs as a fallback (after $PATH, so an existing PATH still wins) so `cairn` resolves:
# go install (any OS), pip/cargo user bins, Homebrew (macOS arm + Intel/unix + Linux).
PATH="$PATH:${GOBIN:-${GOPATH:-$HOME/go}/bin}:$HOME/.local/bin:$HOME/.cargo/bin:/usr/local/bin:/opt/homebrew/bin:/home/linuxbrew/.linuxbrew/bin"
if ! command -v cairn >/dev/null 2>&1; then
  echo "cairn: command not found — install it or add its dir to PATH (https://github.com/IVIR3zaM/Cairn#install)" >&2
  exit 1
fi

cairn commit-lint "$@"
